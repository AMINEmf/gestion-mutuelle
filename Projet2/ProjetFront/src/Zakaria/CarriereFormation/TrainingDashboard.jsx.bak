import React, { useEffect, useMemo, useState } from "react";
import {
  Box,
  Card,
  CardContent,
  Grid,
  ThemeProvider,
  Typography,
  createTheme,
  Toolbar,
} from "@mui/material";
import { BarChart, PieChart } from "@mui/x-charts";
import {
  BookOpen,
  Users,
  CheckCircle,
  DollarSign,
  TrendingUp,
  Target,
} from "lucide-react";
import { useHeader } from "../../Acceuil/HeaderContext";
import { useOpen } from "../../Acceuil/OpenProvider";
import apiClient from "../../services/apiClient";

const themeColors = {
  teal: "#2c767c",
  tealLight: "#4db6ac",
  tealDark: "#004d40",
  secondary: "#26a69a",
  success: "#4caf50",
  warning: "#ff9800",
  error: "#f44336",
  info: "#2196f3",
  textPrimary: "#1e293b",
  textSecondary: "#64748b",
  hoverBg: "#f8fafc",
  divider: "rgba(44, 118, 124, 0.2)",
};

const TrainingDashboard = () => {
  const { setTitle, clearActions } = useHeader();
  const { dynamicStyles } = useOpen();
  const [loading, setLoading] = useState(true);
  const [formations, setFormations] = useState([]);

  useEffect(() => {
    setTitle("Tableau de bord Formations");
    return () => {
      clearActions();
    };
  }, [setTitle, clearActions]);

  useEffect(() => {
    const fetchData = async () => {
      setLoading(true);
      try {
        const res = await apiClient.get("/formations");
        const data = Array.isArray(res.data) ? res.data : (res.data?.data ?? []);
        setFormations(data);
      } catch (error) {
        console.error("Erreur lors du chargement des formations:", error);
        setFormations([]);
      } finally {
        setLoading(false);
      }
    };
    fetchData();
  }, []);

  const StatCard = ({ title, value, icon: Icon, color }) => (
    <Card
      sx={{
        background: `linear-gradient(135deg, ${color}08 0%, ${color}04 100%)`,
        borderRadius: "1.5rem",
        boxShadow: "0 0.25rem 1.25rem rgba(0,0,0,0.08)",
        border: `0.0625rem solid ${color}15`,
        position: "relative",
        overflow: "hidden",
        transition: "all 0.3s cubic-bezier(0.4, 0, 0.2, 1)",
        "&:hover": {
          transform: "translateY(-0.25rem)",
          boxShadow: "0 0.75rem 2.5rem rgba(0,0,0,0.12)",
        },
        "&::before": {
          content: '""',
          position: "absolute",
          top: 0,
          left: 0,
          right: 0,
          height: "0.25rem",
          background: `linear-gradient(90deg, ${themeColors.teal}, ${themeColors.tealLight})`,
        },
      }}
    >
      <CardContent sx={{ p: "1.5rem" }}>
        <Box
          sx={{
            display: "flex",
            alignItems: "flex-start",
            justifyContent: "space-between",
            flexWrap: "wrap",
            gap: "1rem",
          }}
        >
          <Box>
            <Typography
              variant="body2"
              sx={{
                color: themeColors.textSecondary,
                mb: "0.5rem",
                fontWeight: 500,
                fontSize: "0.875rem",
              }}
            >
              {title}
            </Typography>
            <Typography
              variant="h2"
              sx={{
                fontWeight: 700,
                color: themeColors.tealDark,
                fontSize: { xs: "1.5rem", sm: "1.75rem", md: "2rem" },
                lineHeight: 1,
              }}
            >
              {loading ? "..." : value}
            </Typography>
          </Box>
          <Box
            sx={{
              backgroundColor: `${color}26`,
              borderRadius: "1rem",
              p: "0.75rem",
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
              flexShrink: 0,
            }}
          >
            <Icon size={24} color={color} />
          </Box>
        </Box>
      </CardContent>
    </Card>
  );

  const dashboardData = useMemo(() => {
    const active = formations.filter((f) => f.statut === "En cours").length;
    
    // Compter les participants inscrits
    const participantsInscrits = formations.reduce((sum, f) => {
      return sum + (f.participants_count || 0);
    }, 0);

    // Taux de réussite
    const terminated = formations.filter((f) => f.statut === "Terminée" || f.statut === "Termine").length;
    const successRate = formations.length > 0 ? Math.round((terminated / formations.length) * 100) : 0;

    // Budget total
    const budgetTotal = formations.reduce((sum, f) => sum + (Number(f.budget) || 0), 0);

    // Par statut
    const statusCount = {};
    formations.forEach((f) => {
      const s = f.statut || "Non spécifié";
      statusCount[s] = (statusCount[s] || 0) + 1;
    });
    const byStatus = Object.entries(statusCount)
      .map(([label, value], index) => ({ id: index, label, value }))
      .sort((a, b) => b.value - a.value);

    // Budget des 6 derniers mois
    const now = new Date();
    const monthLabels = [];
    const monthData = [];
    for (let i = 5; i >= 0; i--) {
      const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
      const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
      monthLabels.push(d.toLocaleString("fr-FR", { month: "short" }));
      monthData.push(
        formations
          .filter((f) => (f.date_debut || "").startsWith(key))
          .reduce((sum, f) => sum + (Number(f.budget) || 0), 0)
      );
    }

    // Participants par domaine
    const domaineCount = {};
    formations.forEach((f) => {
      const domaine = f.domaine || "Non spécifié";
      const participants = f.participants_count || 0;
      domaineCount[domaine] = (domaineCount[domaine] || 0) + participants;
    });
    const domaineData = Object.entries(domaineCount)
      .map(([label, value]) => ({ label, value }))
      .sort((a, b) => b.value - a.value)
      .slice(0, 6);

    return {
      active,
      participantsInscrits,
      successRate,
      budgetTotal,
      byStatus,
      monthLabels,
      monthData,
      domaineData,
    };
  }, [formations]);

  const kpis = [
    {
      title: "Formations Actives",
      value: dashboardData.active,
      icon: BookOpen,
      color: themeColors.teal,
    },
    {
      title: "Participants Inscrits",
      value: dashboardData.participantsInscrits,
      icon: Users,
      color: themeColors.secondary,
    },
    {
      title: "Taux de Réussite",
      value: `${dashboardData.successRate}%`,
      icon: CheckCircle,
      color: themeColors.success,
    },
    {
      title: "Budget Total Formations",
      value: `${dashboardData.budgetTotal.toLocaleString("fr-FR")} MAD`,
      icon: DollarSign,
      color: themeColors.warning,
    },
  ];

  return (
    <ThemeProvider theme={createTheme()}>
      <Box
        sx={{
          ...dynamicStyles,
          backgroundColor: "#ffffff",
          minHeight: "100vh",
          boxSizing: "border-box",
          p: { xs: "1rem", sm: "1.5rem", md: "2rem" },
          "&::-webkit-scrollbar": {
            width: "0.5rem",
          },
          "&::-webkit-scrollbar-thumb": {
            backgroundColor: "#cbd5e1",
            borderRadius: "0.25rem",
          },
        }}
      >
        <Toolbar />

        {/* Page Title */}
        <Box sx={{ mb: 4 }}>
          <Typography
            variant="h4"
            sx={{ fontSize: "1.5rem", fontWeight: 700, color: themeColors.textPrimary }}
          >
            Tableau de bord Formations
          </Typography>
          <Typography variant="body2" sx={{ color: themeColors.textSecondary, mt: 0.5 }}>
            Suivi des formations, participants et budget
          </Typography>
        </Box>

        {/* KPI Grid */}
        <Grid container spacing={3} sx={{ mb: 4 }}>
          {kpis.map((item) => (
            <Grid item xs={12} sm={6} md={3} key={item.title}>
              <StatCard
                title={item.title}
                value={item.value}
                icon={item.icon}
                color={item.color}
              />
            </Grid>
          ))}
        </Grid>

        {/* Charts Section */}
        <Grid container spacing={3} sx={{ mb: 4 }}>
          {/* Budget par mois */}
          <Grid item xs={12} md={7}>
            <Card
              sx={{
                borderRadius: "1.5rem",
                boxShadow: "0 0.25rem 1.25rem rgba(0,0,0,0.08)",
                border: `0.0625rem solid ${themeColors.divider}`,
              }}
            >
              <CardContent sx={{ p: "1.5rem" }}>
                <Box
                  sx={{
                    display: "flex",
                    alignItems: "center",
                    mb: "1.5rem",
                    flexWrap: "wrap",
                    gap: "0.75rem",
                  }}
                >
                  <Box
                    sx={{
                      backgroundColor: `${themeColors.teal}26`,
                      borderRadius: "0.75rem",
                      p: "0.5rem",
                      display: "flex",
                      alignItems: "center",
                    }}
                  >
                    <TrendingUp size={20} color={themeColors.teal} />
                  </Box>
                  <Typography
                    variant="h6"
                    sx={{
                      fontWeight: 700,
                      fontSize: "1.1rem",
                      color: themeColors.textPrimary,
                    }}
                  >
                    Budget Formation par Mois
                  </Typography>
                </Box>
                {loading ? (
                  <Box sx={{ textAlign: "center", py: 8, color: themeColors.textSecondary }}>
                    Chargement...
                  </Box>
                ) : dashboardData.monthData.length > 0 ? (
                  <Box sx={{ width: "100%", height: 300 }}>
                    <BarChart
                      height={300}
                      xAxis={[{ data: dashboardData.monthLabels, scaleType: "band" }]}
                      series={[{ data: dashboardData.monthData, color: themeColors.teal }]}
                      margin={{ left: 60, right: 20, top: 20, bottom: 40 }}
                    />
                  </Box>
                ) : (
                  <Box sx={{ textAlign: "center", py: 8, color: themeColors.textSecondary }}>
                    Aucune donnée disponible
                  </Box>
                )}
              </CardContent>
            </Card>
          </Grid>

          {/* Répartition par statut */}
          <Grid item xs={12} md={5}>
            <Card
              sx={{
                borderRadius: "1.5rem",
                boxShadow: "0 0.25rem 1.25rem rgba(0,0,0,0.08)",
                border: `0.0625rem solid ${themeColors.divider}`,
              }}
            >
              <CardContent sx={{ p: "1.5rem" }}>
                <Box
                  sx={{
                    display: "flex",
                    alignItems: "center",
                    mb: "1.5rem",
                    flexWrap: "wrap",
                    gap: "0.75rem",
                  }}
                >
                  <Box
                    sx={{
                      backgroundColor: `${themeColors.info}26`,
                      borderRadius: "0.75rem",
                      p: "0.5rem",
                      display: "flex",
                      alignItems: "center",
                    }}
                  >
                    <CheckCircle size={20} color={themeColors.info} />
                  </Box>
                  <Typography
                    variant="h6"
                    sx={{
                      fontWeight: 700,
                      fontSize: "1.1rem",
                      color: themeColors.textPrimary,
                    }}
                  >
                    Répartition par Statut
                  </Typography>
                </Box>
                {loading ? (
                  <Box sx={{ textAlign: "center", py: 8, color: themeColors.textSecondary }}>
                    Chargement...
                  </Box>
                ) : dashboardData.byStatus.length > 0 ? (
                  <Box sx={{ width: "100%", height: 300 }}>
                    <PieChart
                      height={300}
                      series={[
                        {
                          data: dashboardData.byStatus,
                          innerRadius: 50,
                          outerRadius: 120,
                          paddingAngle: 2,
                        },
                      ]}
                      margin={{ left: 20, right: 20, top: 20, bottom: 20 }}
                    />
                  </Box>
                ) : (
                  <Box sx={{ textAlign: "center", py: 8, color: themeColors.textSecondary }}>
                    Aucune donnée disponible
                  </Box>
                )}
              </CardContent>
            </Card>
          </Grid>

          {/* Participants par domaine */}
          <Grid item xs={12}>
            <Card
              sx={{
                borderRadius: "1.5rem",
                boxShadow: "0 0.25rem 1.25rem rgba(0,0,0,0.08)",
                border: `0.0625rem solid ${themeColors.divider}`,
              }}
            >
              <CardContent sx={{ p: "1.5rem" }}>
                <Box
                  sx={{
                    display: "flex",
                    alignItems: "center",
                    mb: "1.5rem",
                    flexWrap: "wrap",
                    gap: "0.75rem",
                  }}
                >
                  <Box
                    sx={{
                      backgroundColor: `${themeColors.secondary}26`,
                      borderRadius: "0.75rem",
                      p: "0.5rem",
                      display: "flex",
                      alignItems: "center",
                    }}
                  >
                    <Target size={20} color={themeColors.secondary} />
                  </Box>
                  <Typography
                    variant="h6"
                    sx={{
                      fontWeight: 700,
                      fontSize: "1.1rem",
                      color: themeColors.textPrimary,
                    }}
                  >
                    Participants par Domaine
                  </Typography>
                </Box>
                {loading ? (
                  <Box sx={{ textAlign: "center", py: 8, color: themeColors.textSecondary }}>
                    Chargement...
                  </Box>
                ) : dashboardData.domaineData.length > 0 ? (
                  <Box sx={{ width: "100%", height: 300 }}>
                    <BarChart
                      height={300}
                      xAxis={[
                        {
                          data: dashboardData.domaineData.map((d) => d.label),
                          scaleType: "band",
                        },
                      ]}
                      series={[
                        {
                          data: dashboardData.domaineData.map((d) => d.value),
                          color: themeColors.secondary,
                        },
                      ]}
                      margin={{ left: 40, right: 20, top: 20, bottom: 60 }}
                    />
                  </Box>
                ) : (
                  <Box sx={{ textAlign: "center", py: 8, color: themeColors.textSecondary }}>
                    Aucune donnée disponible
                  </Box>
                )}
              </CardContent>
            </Card>
          </Grid>
        </Grid>
      </Box>
    </ThemeProvider>
  );
};

export default TrainingDashboard;
  const { setTitle, clearActions } = useHeader();
  const { dynamicStyles } = useOpen();
  const [loading, setLoading] = useState(true);
  const [formations, setFormations] = useState([]);

  useEffect(() => {
    setTitle("Tableau de bord Formations");
    return () => {
      clearActions();
    };
  }, [setTitle, clearActions]);

  useEffect(() => {
    const fetchData = async () => {
      setLoading(true);
      try {
        const res = await apiClient.get("/formations");
        const data = Array.isArray(res.data) ? res.data : (res.data?.data ?? []);
        setFormations(data);
      } catch (error) {
        console.error("Erreur lors du chargement des formations:", error);
        setFormations([]);
      } finally {
        setLoading(false);
      }
    };
    fetchData();
  }, []);

  const StatCard = ({ title, value, icon: Icon, color }) => (
    <Card
      sx={{
        background: `linear-gradient(135deg, ${color}08 0%, ${color}04 100%)`,
        borderRadius: "1.5rem",
        boxShadow: "0 0.25rem 1.25rem rgba(0,0,0,0.08)",
        border: `0.0625rem solid ${color}15`,
        position: "relative",
        overflow: "hidden",
        transition: "all 0.3s cubic-bezier(0.4, 0, 0.2, 1)",
        "&:hover": {
          transform: "translateY(-0.25rem)",
          boxShadow: "0 0.75rem 2.5rem rgba(0,0,0,0.12)",
        },
        "&::before": {
          content: '""',
          position: "absolute",
          top: 0,
          left: 0,
          right: 0,
          height: "0.25rem",
          background: `linear-gradient(90deg, ${themeColors.teal}, ${themeColors.tealLight})`,
        },
      }}
    >
      <CardContent sx={{ p: "1.5rem" }}>
        <Box
          sx={{
            display: "flex",
            alignItems: "flex-start",
            justifyContent: "space-between",
            flexWrap: "wrap",
            gap: "1rem",
          }}
        >
          <Box>
            <Typography
              variant="body2"
              sx={{
                color: themeColors.textSecondary,
                mb: "0.5rem",
                fontWeight: 500,
                fontSize: "0.875rem",
              }}
            >
              {title}
            </Typography>
            <Typography
              variant="h2"
              sx={{
                fontWeight: 700,
                color: themeColors.tealDark,
                fontSize: { xs: "1.5rem", sm: "1.75rem", md: "2rem" },
                lineHeight: 1,
              }}
            >
              {loading ? "..." : value}
            </Typography>
          </Box>
          <Box
            sx={{
              backgroundColor: `${color}26`,
              borderRadius: "1rem",
              p: "0.75rem",
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
              flexShrink: 0,
            }}
          >
            <Icon size={24} color={color} />
          </Box>
        </Box>
      </CardContent>
    </Card>
  );

  const { active, participantsInscrits, successRate, budgetTotal, byStatus, monthLabels, monthData, domaineData } = useMemo(() => {
    const active = formations.filter((f) => f.statut === "En cours").length;
    
    // Compter les participants inscrits
    const participantsInscrits = formations.reduce((sum, f) => {
      return sum + (f.participants_count || 0);
    }, 0);

    // Taux de réussite
    const terminated = formations.filter((f) => f.statut === "Terminée" || f.statut === "Termine").length;
    const successRate = formations.length > 0 ? Math.round((terminated / formations.length) * 100) : 0;

    // Budget total
    const budgetTotal = formations.reduce((sum, f) => sum + (Number(f.budget) || 0), 0);

    // Par statut
    const statusCount = {};
    formations.forEach((f) => {
      const s = f.statut || "Non spécifié";
      statusCount[s] = (statusCount[s] || 0) + 1;
    });
    const byStatus = Object.entries(statusCount)
      .map(([label, value], index) => ({ id: index, label, value }))
      .sort((a, b) => b.value - a.value);

    // Budget des 6 derniers mois
    const now = new Date();
    const monthLabels = [];
    const monthData = [];
    for (let i = 5; i >= 0; i--) {
      const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
      const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
      monthLabels.push(d.toLocaleString("fr-FR", { month: "short" }));
      monthData.push(
        formations
          .filter((f) => (f.date_debut || "").startsWith(key))
          .reduce((sum, f) => sum + (Number(f.budget) || 0), 0)
      );
    }

    // Participants par domaine
    const domaineCount = {};
    formations.forEach((f) => {
      const domaine = f.domaine || "Non spécifié";
      const participants = f.participants_count || 0;
      domaineCount[domaine] = (domaineCount[domaine] || 0) + participants;
    });
    const domaineData = Object.entries(domaineCount)
      .map(([label, value]) => ({ label, value }))
      .sort((a, b) => b.value - a.value)
      .slice(0, 6); // Top 6 domaines

    return { active, participantsInscrits, successRate, budgetTotal, byStatus, monthLabels, monthData, domaineData };
  }, [formations]);

  const kpis = [
    {
      title: "Formations Actives",
      value: active,
      icon: BookOpen,
      color: themeColors.teal,
    },
    {
      title: "Participants Inscrits",
      value: participantsInscrits,
      icon: Users,
      color: themeColors.secondary,
    },
    {
      title: "Taux de Réussite",
      value: `${successRate}%`,
      icon: CheckCircle,
      color: themeColors.success,
    },
    {
      title: "Budget Total Formations",
      value: `${budgetTotal.toLocaleString("fr-FR")} MAD`,
      icon: DollarSign,
      color: themeColors.warning,
    },
  ];

  return (
    <ThemeProvider theme={createTheme()}>
      <Box
        sx={{
          ...dynamicStyles,
          backgroundColor: "#ffffff",
          minHeight: "100vh",
          overflowY: "auto",
          p: { xs: "1rem", sm: "1.5rem", md: "2rem" },
          "&::-webkit-scrollbar": {
            width: "0.5rem",
          },
          "&::-webkit-scrollbar-thumb": {
            backgroundColor: "#cbd5e1",
            borderRadius: "0.25rem",
          },
        }}
      >
        <Toolbar />

        {/* Page Title */}
        <Box sx={{ mb: 4 }}>
          <Typography
            variant="h4"
            sx={{ fontSize: "1.5rem", fontWeight: 700, color: themeColors.textPrimary }}
          >
            Tableau de bord Formations
          </Typography>
          <Typography variant="body2" sx={{ color: themeColors.textSecondary, mt: 0.5 }}>
            Suivi des formations, participants et budget
          </Typography>
        </Box>

        {/* KPI Grid */}
        <Grid container spacing={3} sx={{ mb: 4 }}>
          {kpis.map((item) => (
            <Grid item xs={12} sm={6} md={3} key={item.title}>
              <StatCard
                title={item.title}
                value={item.value}
                icon={item.icon}
                color={item.color}
              />
            </Grid>
          ))}
        </Grid>

        {/* Charts Section */}
        <Grid container spacing={3} sx={{ mb: 4 }}>
          {/* Budget par mois */}
          <Grid item xs={12} md={7}>
            <Card
              sx={{
                borderRadius: "1.5rem",
                boxShadow: "0 0.25rem 1.25rem rgba(0,0,0,0.08)",
                border: `0.0625rem solid ${themeColors.divider}`,
              }}
            >
              <CardContent sx={{ p: "1.5rem" }}>
                <Box
                  sx={{
                    display: "flex",
                    alignItems: "center",
                    mb: "1.5rem",
                    flexWrap: "wrap",
                    gap: "0.75rem",
                  }}
                >
                  <Box
                    sx={{
                      backgroundColor: `${themeColors.teal}26`,
                      borderRadius: "0.75rem",
                      p: "0.5rem",
                      display: "flex",
                      alignItems: "center",
                    }}
                  >
                    <TrendingUp size={20} color={themeColors.teal} />
                  </Box>
                  <Typography
                    variant="h6"
                    sx={{
                      fontWeight: 700,
                      fontSize: "1.1rem",
                      color: themeColors.textPrimary,
                    }}
                  >
                    Budget Formation par Mois
                  </Typography>
                </Box>
                <Box sx={{ width: "100%", height: 300 }}>
                  <BarChart
                    height={300}
                    xAxis={[{ data: monthLabels, scaleType: "band" }]}
                    series={[{ data: monthData, color: themeColors.teal }]}
                    margin={{ left: 60, right: 20, top: 20, bottom: 40 }}
                  />
                </Box>
              </CardContent>
            </Card>
          </Grid>

          {/* Répartition par statut */}
          <Grid item xs={12} md={5}>
            <Card
              sx={{
                borderRadius: "1.5rem",
                boxShadow: "0 0.25rem 1.25rem rgba(0,0,0,0.08)",
                border: `0.0625rem solid ${themeColors.divider}`,
              }}
            >
              <CardContent sx={{ p: "1.5rem" }}>
                <Box
                  sx={{
                    display: "flex",
                    alignItems: "center",
                    mb: "1.5rem",
                    flexWrap: "wrap",
                    gap: "0.75rem",
                  }}
                >
                  <Box
                    sx={{
                      backgroundColor: `${themeColors.info}26`,
                      borderRadius: "0.75rem",
                      p: "0.5rem",
                      display: "flex",
                      alignItems: "center",
                    }}
                  >
                    <CheckCircle size={20} color={themeColors.info} />
                  </Box>
                  <Typography
                    variant="h6"
                    sx={{
                      fontWeight: 700,
                      fontSize: "1.1rem",
                      color: themeColors.textPrimary,
                    }}
                  >
                    Répartition par Statut
                  </Typography>
                </Box>
                <Box sx={{ width: "100%", height: 300 }}>
                  <PieChart
                    height={300}
                    series={[
                      {
                        data:
                          byStatus.length > 0
                            ? byStatus
                            : [{ id: 0, label: "Aucune donnée", value: 1 }],
                        innerRadius: 50,
                        outerRadius: 120,
                        paddingAngle: 2,
                      },
                    ]}
                    margin={{ left: 20, right: 20, top: 20, bottom: 20 }}
                  />
                </Box>
              </CardContent>
            </Card>
          </Grid>

          {/* Participants par domaine */}
          <Grid item xs={12}>
            <Card
              sx={{
                borderRadius: "1.5rem",
                boxShadow: "0 0.25rem 1.25rem rgba(0,0,0,0.08)",
                border: `0.0625rem solid ${themeColors.divider}`,
              }}
            >
              <CardContent sx={{ p: "1.5rem" }}>
                <Box
                  sx={{
                    display: "flex",
                    alignItems: "center",
                    mb: "1.5rem",
                    flexWrap: "wrap",
                    gap: "0.75rem",
                  }}
                >
                  <Box
                    sx={{
                      backgroundColor: `${themeColors.secondary}26`,
                      borderRadius: "0.75rem",
                      p: "0.5rem",
                      display: "flex",
                      alignItems: "center",
                    }}
                  >
                    <Target size={20} color={themeColors.secondary} />
                  </Box>
                  <Typography
                    variant="h6"
                    sx={{
                      fontWeight: 700,
                      fontSize: "1.1rem",
                      color: themeColors.textPrimary,
                    }}
                  >
                    Participants par Domaine
                  </Typography>
                </Box>
                <Box sx={{ width: "100%", height: 300 }}>
                  <BarChart
                    height={300}
                    xAxis={[
                      {
                        data: domaineData.map((d) => d.label),
                        scaleType: "band",
                      },
                    ]}
                    series={[
                      {
                        data: domaineData.map((d) => d.value),
                        color: themeColors.secondary,
                      },
                    ]}
                    margin={{ left: 40, right: 20, top: 20, bottom: 60 }}
                  />
                </Box>
              </CardContent>
            </Card>
          </Grid>
        </Grid>
      </Box>
    </ThemeProvider>
  );
};

export default TrainingDashboard;

